---
import Container from "@components/elements/Container.astro";
import Layout from "@layouts/Layout.astro";

const steps = [
  {
    n: "01",
    title: "Montando una revista o una newsletter",
    text: "O algo del estilo donde poder compartiros alternativas tech, consejos y otras cosas interesantes para poder acercaros a este mundillo.",
  },
  {
    n: "02",
    title: "Construyendo iniciativas para distintas causas sociales",
    text: "Nos movemos en un mundo completamente tecnológico, y, muchas veces, por falta de financiación, no disponemos de todas las herramientas que nos gustaría para apoyar las causas sociales que apoyamos, es ahí es donde queremos ayudar nosotras.",
  },
  {
    n: "03",
    title: "Haciendo talleres para aprender a recuperar la tecnología",
    text: "Queremos que todas le podamos dar una segunda vida a nuestros dispositivos, aprender cosas chulas y útiles y sobretodo generar un espacio donde construir entre todas.",
  },
];
---

<Layout
  title="Inicio"
  description="Un proyecto autogestionado que nace de una motivación común: recuperar la tecnología."
>

  <!-- Hero -->
  <section class="hero-section relative min-h-screen flex items-start sm:items-center overflow-hidden bg-base-100">
    <div class="hero-dots absolute inset-0 pointer-events-none"></div>
    <Container class="relative z-10 pt-16 pb-16 sm:py-32">
      <div class="max-w-3xl">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-tight mb-6">
          Creemos que la tecnología puede ser útil, ética y nuestra
        </h1>
        <p class="text-lg sm:text-xl text-base-content/70 max-w-xl mb-10">
          Sigue de cerca lo que estamos montando para no perderte nada.
        </p>
        <a href="#proyecto" class="btn btn-primary btn-lg">
          Conoce el proyecto
        </a>
      </div>
    </Container>
  </section>

  <div class="divider mx-auto max-w-5xl px-6"></div>

  <!-- Introducing -->
  <section id="proyecto" class="py-24 lg:py-36">
    <Container>
      <div class="max-w-2xl mx-auto text-center space-y-6">
        <h2 class="text-3xl sm:text-4xl font-light leading-snug">
          Un proyecto autogestionado que nace de una motivación común de las personas que lo construyen.
        </h2>
        <p class="text-base-content/70 text-lg">
          Nos inspiramos en otras iniciativas que nacen de tratar recuperar el mundo que habitamos, cada una por supuesto, desde su prisma y su terreno, pero queriendo escapar del algoritmo que nos controla día tras día.
        </p>
        <a href="#como" class="btn btn-outline">Cómo lo hacemos</a>
      </div>
    </Container>
  </section>

  <div class="divider mx-auto max-w-5xl px-6"></div>

  <!-- Steps -->
  <section id="como" class="py-24 lg:py-36 bg-base-200">
    <Container>
      <h2 class="text-3xl sm:text-4xl font-light mb-16">Cómo lo vamos a hacer</h2>
      <div>
        {steps.map((item) => (
          <div class="flex gap-8 py-10 border-b border-base-300 last:border-0">
            <span class="text-4xl font-bold text-primary/40 shrink-0 w-14">{item.n}</span>
            <div class="space-y-3">
              <h3 class="text-xl font-light">{item.title}</h3>
              <p class="text-base-content/70">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </Container>
  </section>

</Layout>

<style>
  .hero-dots {
    background-color: transparent;
    background-image: radial-gradient(var(--color-base-300) 1px, transparent 1px);
    background-size: 16px 16px;
    mask-image: radial-gradient(ellipse 50% 50% at 50% 50%, #000 70%, transparent 100%);
  }

  [data-theme="dark"] .hero-dots {
    background-color: #00091d;
    background-image: radial-gradient(#ffffff33 1px, #00091d 1px);
    background-size: 20px 20px;
    mask-image: radial-gradient(ellipse 50% 50% at 50% 50%, #000 70%, transparent 100%);
  }
</style>

