---
import { Icon } from 'astro-icon/components'
import Container from "@components/elements/Container.astro";
import { siteConfig } from "site-config";
import { nav } from "site-config";
import ThemeToggle from "@components/ThemeToggle.astro";
import Logo from "../../icons/logo.svg?raw";

const pathname = Astro.url.pathname;
const isActive = (url: string) => url === "/" ? pathname === "/" : pathname === url || pathname.startsWith(`${url}/`);
---

<div
  x-data="{ open: false }"
  x-on:astro:page-load.document="open = false"
  @keydown.escape.window="open = false"
>
  <header class="border-b border-base-300 bg-base-100">
    <Container>
      <nav class="navbar min-h-16 px-0">
        <div class="navbar-start">
          <a href="/" class="btn btn-ghost px-0 hover:bg-transparent" aria-label={siteConfig.title}>
            <span class="block h-28 w-auto [&_svg]:h-full [&_svg]:w-auto [&_path]:fill-current" set:html={Logo} />
          </a>
        </div>

        <div class="navbar-end gap-2">
          <ul class="menu menu-horizontal hidden gap-1 px-0 md:flex">
            {nav.map((item) => (
              <li>
                <a
                  href={item.url}
                  class:list={[
                    "rounded-btn",
                    isActive(item.url) && "active",
                  ]}
                  aria-current={isActive(item.url) ? "page" : undefined}
                >
                  {item.text}
                </a>
              </li>
            ))}
          </ul>

          <ThemeToggle />

          <button @click="open = !open" class="btn btn-square btn-ghost md:hidden" aria-label="Open menu">
            <Icon name="nav" />
          </button>
        </div>
      </nav>
    </Container>
  </header>

  <!-- Dedicated mobile overlay layer; kept outside the header/container so it fully covers the viewport. -->
  <div
    x-cloak
    x-show="open"
    x-transition:enter="transition ease-out duration-100"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-100"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 z-50 bg-primary md:hidden"
  >
    <button
      @click="open = false"
      class="btn btn-square btn-ghost absolute top-6 right-6 text-primary-content hover:bg-primary-content/10"
      aria-label="Close menu"
    >
      ✕
    </button>

    <div class="flex min-h-full flex-col items-center justify-center gap-6 px-6 text-center">
      {nav.map((item) => (
        <a
          href={item.url}
          class:list={[
            "text-2xl text-primary-content transition-colors hover:text-accent",
            isActive(item.url) && "font-semibold underline underline-offset-8",
          ]}
          aria-current={isActive(item.url) ? "page" : undefined}
          @click="open = false"
        >
          {item.text}
        </a>
      ))}
    </div>
  </div>
</div>
